{
  "manifest_version": 3,
  "name": "TabGroup Master",
  "version": "2.0.0",
  "key": "",
  "description": "Capture, organize, and restore your Chrome tab groups with nested folders and JSON backup.",
  "permissions": [
    "tabGroups",
    "tabs",
    "sidePanel",
    "storage",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "TabGroup Master"
  },
  "options_page": "dashboard.html"
}
